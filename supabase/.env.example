# Local Edge Function values only. Copy to supabase/.env; never commit that file.
API_FOOTBALL_KEY=replace-with-your-provider-key
SYNC_CRON_SECRET=replace-with-a-long-random-value
API_DAILY_STOP_AT=90
ALLOWED_ORIGIN=http://localhost:5173

# Hosted Edge Functions receive these automatically from Supabase. They are
# listed here only to make the local runtime contract explicit.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=provided-by-supabase-start
SUPABASE_SERVICE_ROLE_KEY=provided-by-supabase-start
